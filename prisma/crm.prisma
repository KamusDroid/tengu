// prisma/crm.prisma
datasource db {
  provider = "postgresql"
  url      = env("CRM_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/crm"
}

model Customer {
  id        String   @id @default(uuid())
  userId    String?
  fullName  String
  email     String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(uuid())
  titulo      String
  slug        String    @unique
  categoria   String?
  extracto    String?
  contenido   String
  imagenUrl   String?
  publicado   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Taller {
  id            String        @id @default(uuid())
  titulo        String
  nivel         String?
  modalidad     String?
  descripcion   String?
  precio        Int?
  fecha         DateTime?
  cupoMaximo    Int?
  activo        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  inscripciones Inscripcion[]
}

model Inscripcion {
  id        String   @id @default(uuid())
  taller    Taller   @relation(fields: [tallerId], references: [id])
  tallerId  String
  nombre    String
  email     String
  telefono  String?
  estado    String   @default("pendiente")
  createdAt DateTime @default(now())
}

model ConfiguracionSitio {
  id    String @id @default(uuid())
  clave String @unique
  valor String
}

model BillingClient {
  id                 String    @id @default(uuid())
  nombre             String
  email              String?
  telefono           String?
  industria          String?
  cuit               String?
  direccion          String?
  datosPago          String?
  valorMensual       Int       @default(0)
  moneda             String    @default("ARS")
  inicioContrato     DateTime?
  renovacionContrato DateTime?
  estado             String    @default("active")
  notas              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  facturas           Invoice[]
}

model Invoice {
  id            String        @id @default(uuid())
  numero        String        @unique
  cliente       BillingClient @relation(fields: [clienteId], references: [id])
  clienteId     String
  descripcion   String?
  items         String?
  subtotal      Int           @default(0)
  tasaIva       Int           @default(21)
  montoIva      Int           @default(0)
  descuento     Int           @default(0)
  total         Int           @default(0)
  moneda        String        @default("ARS")
  estado        String        @default("draft")
  emitidaEn     DateTime      @default(now())
  venceEn       DateTime
  pagadaEn      DateTime?
  notas         String?
  datosPago     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
